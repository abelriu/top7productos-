# ---------------------------------------------------------------
# SEGURIDAD — Top7productos
# ---------------------------------------------------------------

# --- Forzar HTTPS -------------------------------------------------
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Cabeceras de seguridad HTTP ----------------------------------
<IfModule mod_headers.c>

    # Evita que el sitio sea embebido en iframes (clickjacking)
    Header always set X-Frame-Options "DENY"

    # Evita que el navegador adivine el tipo MIME
    Header always set X-Content-Type-Options "nosniff"

    # Controla qué información de referrer se envía a terceros
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Deshabilita APIs del navegador que no se usan
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"

    # Fuerza HTTPS durante 1 año (activar solo cuando HTTPS esté estable)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy
    # - Scripts: solo locales + jsDelivr (Bootstrap)
    # - Estilos: solo locales + Google Fonts
    # - Fuentes: solo locales + Google Fonts
    # - Imágenes: locales + HTTPS (para Amazon, etc.)
    # - Sin iframes
    Header always set Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://top7-paapi.t7productos.workers.dev; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"

</IfModule>

# --- Ocultar cabecera Server y versión de Apache ------------------
ServerSignature Off
<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# --- Bloquear acceso a ficheros sensibles -------------------------
<FilesMatch "(^\.htaccess|\.git|\.env|composer\.(json|lock)|package(-lock)?\.json)">
    Order allow,deny
    Deny from all
</FilesMatch>

# --- Evitar listado de directorios --------------------------------
Options -Indexes

# --- Página de error personalizada --------------------------------
ErrorDocument 404 /404.html

# --- Comprimir respuestas (rendimiento) ---------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# --- Cache de activos estáticos (rendimiento) ---------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType image/jpeg                "access plus 3 months"
    ExpiresByType image/png                 "access plus 3 months"
    ExpiresByType image/webp                "access plus 3 months"
    ExpiresByType image/svg+xml             "access plus 3 months"
    ExpiresByType font/woff2                "access plus 6 months"
</IfModule>
